# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- spark-agent-engine BFF integration (see spark-agent-docs/frontend-backend-integration-strategy.md) ---
# These are read only inside app/api/**/route.ts (server-side) — never exposed to the browser,
# so intentionally NOT prefixed with NEXT_PUBLIC_.

# BACKEND_ENGINE_URL: base URL of the spark-agent-engine REST API.
BACKEND_ENGINE_URL="http://localhost:8080"

# BACKEND_SOURCE_DEVICE / BACKEND_SOURCE_ALERT: per-resource strangler-fig flag.
# "engine" = proxy spark-agent-engine; "mock" (default if unset) = lib/db.ts in-memory mock.
# Independent per resource so a bad flip can be reverted without affecting the other or requiring
# a spark-agent-engine redeploy.
BACKEND_SOURCE_DEVICE="mock"
BACKEND_SOURCE_ALERT="mock"

# NEXT_PUBLIC_BACKEND_WS_URL: spark-agent-engine's STOMP/SockJS endpoint, read directly by the
# browser (hence NEXT_PUBLIC_ — unlike BACKEND_ENGINE_URL above, this one IS exposed to the client,
# since the WS connection is opened browser-to-engine directly, not proxied through this BFF).
# Leave unset to stay in mock mode — the WS hooks no-op and the app falls back to the existing
# 4s REST poll (src/features/telemetry/hooks.ts). Only set this when BACKEND_SOURCE_DEVICE/ALERT
# are both "engine", and make sure the engine's app.ws-allowed-origins includes this app's origin.
NEXT_PUBLIC_BACKEND_WS_URL="http://localhost:8080/ws"
